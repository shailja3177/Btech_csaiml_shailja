#include <stdio.h>

int main() {
    int m, n;
    static int array[10][10]; 
    int i, j, row_sum = 0, col_sum = 0;

    printf("Enter the order of the matrix (rows and columns):\\n");
    scanf("%d %d", &m, &n);

    printf("Enter the co-efficients (elements) of the matrix:\\n");
    for (i = 0; i < m; ++i) {
        for (j = 0; j < n; ++j) {
            scanf("%d", &array[i][j]);
        }
    }

    printf("\\nThe matrix is:\\n");
    for (i = 0; i < m; ++i) {
        for (j = 0; j < n; ++j) {
            printf("% 4d", array[i][j]);
        }
        printf("\\n");
    }

    printf("\\nSum of each row:\\n");
    for (i = 0; i < m; ++i) {
        row_sum = 0;
        for (j = 0; j < n; ++j) {
            row_sum += array[i][j];
        }
        printf("Sum of row %d is = %d\\n", i, row_sum);
    }

    printf("\\nSum of each column:\\n");
    for (j = 0; j < n; ++j) {
        col_sum = 0; 
        for (i = 0; i < m; ++i) {
            col_sum += array[i][j];
        }
        printf("Sum of column %d is = %d\\n", j, col_sum);
    }

    return 0;
}
